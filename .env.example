# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/media_pipeline

# Redis (used by BullMQ)
# Local/Docker: use host/port below. Managed free hosting (e.g. Upstash): set REDIS_URL
# instead (rediss://default:password@host:port) and leave host/port blank.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage (Cloudinary -- required, since API and worker run as separate containers
# with no shared filesystem; get these free from cloudinary.com dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_UPLOAD_SIZE_MB=15

# Analysis thresholds (tunable without code changes)
BLUR_LAPLACIAN_THRESHOLD=100
LOW_LIGHT_LUMINANCE_THRESHOLD=60
BRIGHT_LUMINANCE_THRESHOLD=235
DUPLICATE_HAMMING_DISTANCE_THRESHOLD=5
MIN_IMAGE_WIDTH=400
MIN_IMAGE_HEIGHT=300

# Queue
QUEUE_CONCURRENCY=2
QUEUE_MAX_ATTEMPTS=3
